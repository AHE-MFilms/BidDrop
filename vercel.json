{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/privacy",
      "destination": "/privacy.html"
    },
    {
      "source": "/signup",
      "destination": "/signup.html"
    },
    {
      "source": "/r/:id",
      "destination": "/api/r"
    },
    {
      "source": "/q/:slug",
      "destination": "/index.html"
    },
    {
      "source": "/e/:id",
      "destination": "/estimate.html"
    },
    {
      "source": "/open",
      "destination": "/open.html"
    },
    {
      "source": "/api/oauth/callback",
      "destination": "/api/oauth"
    },
    {
      "source": "/favicon.ico",
      "destination": "/favicon.ico"
    },
    {
      "source": "/manifest.json",
      "destination": "/manifest.json"
    },
    {
      "source": "/:company((?!api|favicon\\.ico|manifest\\.json|icon-)[^/]+)/:id",
      "destination": "/estimate.html"
    }
  ],
  "crons": [
    {
      "path": "/api/cron-drip",
      "schedule": "0 13 * * *"
    },
    {
      "path": "/api/cron-trial-check",
      "schedule": "5 13 * * *"
    },
    {
      "path": "/api/cron-purge-trash",
      "schedule": "0 2 * * *"
    }
  ],
  "functions": {
    "api/credits.js":          { "maxDuration": 30 },
    "api/quote.js":            { "maxDuration": 15 },
    "api/estimate.js":         { "maxDuration": 15 },
    "api/oauth.js":            { "maxDuration": 15 },
    "api/cron-drip.js":        { "maxDuration": 60 },
    "api/signup.js":           { "maxDuration": 15 },
    "api/signup-webhook.js":   { "maxDuration": 30 },
    "api/cron-trial-check.js": { "maxDuration": 30 },
    "api/billing-webhook.js":  { "maxDuration": 30 },
    "api/admin.js":            { "maxDuration": 60 },
    "api/admin-users.js":      { "maxDuration": 30 },
    "api/admin-ghl.js":        { "maxDuration": 30 },
    "api/admin-lob.js":        { "maxDuration": 60 },
    "api/admin-rentcast.js":   { "maxDuration": 15 },
    "api/admin-storage.js":    { "maxDuration": 30 },
    "api/admin-misc.js":       { "maxDuration": 60 },
    "api/solar.js":            { "maxDuration": 10 },
    "api/jobnimbus.js":        { "maxDuration": 15 },
    "api/send-proposal.js":    { "maxDuration": 15 },
    "api/migrate.js":          { "maxDuration": 30 },
    "api/cron-purge-trash.js": { "maxDuration": 30 },
    "api/r.js":                { "maxDuration": 15 },
    "api/pixel.js":            { "maxDuration": 10 },
    "api/canvas.js":           { "maxDuration": 15 },
    "api/storm-proxy.js":       { "maxDuration": 15 },
    "api/health.js":            { "maxDuration": 10 }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(self)"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.jsdelivr.net https://cdnjs.cloudflare.com https://fonts.googleapis.com https://maps.googleapis.com https://maps.gstatic.com https://www.googletagmanager.com https://js.stripe.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https://*.supabase.co https://*.tile.openstreetmap.org https://*.basemaps.cartocdn.com https://tile.openstreetmap.org https://maps.googleapis.com https://maps.gstatic.com https://*.googleapis.com https://api.mapbox.com https://*.mapbox.com https://api.qrserver.com; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://api.lob.com https://api.rentcast.io https://api.tracerfy.com https://api.companycam.com https://rest.gohighlevel.com https://services.leadconnectorhq.com https://api.stripe.com https://api.quickbooks.com https://api.jobnimbus.com https://api.openai.com https://api.mapbox.com https://events.mapbox.com; frame-src https://js.stripe.com https://hooks.stripe.com; object-src 'none'; base-uri 'self'; form-action 'self';"
        }
      ]
    }
  ]
}
