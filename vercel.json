{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/privacy",
      "destination": "/privacy.html"
    },
    {
      "source": "/signup",
      "destination": "/signup.html"
    },
    {
      "source": "/r/:id",
      "destination": "/api/r"
    },
    {
      "source": "/q/:slug",
      "destination": "/index.html"
    },
    {
      "source": "/e/:id",
      "destination": "/estimate.html"
    },
    {
      "source": "/open",
      "destination": "/open.html"
    },
    {
      "source": "/api/oauth/callback",
      "destination": "/api/oauth"
    },
    {
      "source": "/favicon.ico",
      "destination": "/favicon.ico"
    },
    {
      "source": "/manifest.json",
      "destination": "/manifest.json"
    },
    {
      "source": "/:company((?!api|favicon\\.ico|manifest\\.json|icon-)[^/]+)/:id",
      "destination": "/estimate.html"
    }
  ],
  "crons": [
    {
      "path": "/api/cron-drip",
      "schedule": "0 13 * * *"
    },
    {
      "path": "/api/cron-trial-check",
      "schedule": "0 13 * * *"
    }
  ],
  "functions": {
    "api/credits.js": {
      "maxDuration": 30
    },
    "api/quote.js": {
      "maxDuration": 15
    },
    "api/estimate.js": {
      "maxDuration": 15
    },
    "api/oauth.js": {
      "maxDuration": 15
    },
    "api/cron-drip.js": {
      "maxDuration": 60
    },
    "api/signup.js": {
      "maxDuration": 15
    },
    "api/signup-webhook.js": {
      "maxDuration": 30
    },
    "api/cron-trial-check.js": {
      "maxDuration": 30
    },
    "api/billing-webhook.js": {
      "maxDuration": 30
    },
    "api/admin.js": {
      "maxDuration": 30
    },
    "api/solar.js": {
      "maxDuration": 10
    },
    "api/jobnimbus.js": {
      "maxDuration": 15
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate"
        }
      ]
    }
  ]
}