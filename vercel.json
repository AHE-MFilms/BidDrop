{
  "rewrites": [
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/r/:id", "destination": "/api/r" },
    { "source": "/q/:slug", "destination": "/index.html" },
    { "source": "/e/:id", "destination": "/estimate.html" },
    { "source": "/open", "destination": "/open.html" },
    { "source": "/:company((?!api)[^/]+)/:id", "destination": "/estimate.html" }
  ],
  "functions": {
    "api/credits.js": {
      "maxDuration": 30
    },
    "api/quote.js": {
      "maxDuration": 15
    },
    "api/estimate.js": {
      "maxDuration": 15
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate"
        }
      ]
    }
  ]
}
