{
  "rewrites": [
    {
      "source": "/privacy",
      "destination": "/privacy.html"
    },
    {
      "source": "/r/:id",
      "destination": "/api/r"
    },
    {
      "source": "/q/:slug",
      "destination": "/index.html"
    },
    {
      "source": "/e/:id",
      "destination": "/estimate.html"
    },
    {
      "source": "/open",
      "destination": "/open.html"
    },
    {
      "source": "/api/oauth/callback",
      "destination": "/api/oauth"
    },
    {
      "source": "/:company((?!api)[^/]+)/:id",
      "destination": "/estimate.html"
    }
  ],
  "crons": [
    {
      "path": "/api/cron-drip",
      "schedule": "0 13 * * *"
    }
  ],
  "functions": {
    "api/credits.js": {
      "maxDuration": 30
    },
    "api/quote.js": {
      "maxDuration": 15
    },
    "api/estimate.js": {
      "maxDuration": 15
    },
    "api/oauth.js": {
      "maxDuration": 15
    },
    "api/cron-drip.js": {
      "maxDuration": 60
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate"
        }
      ]
    }
  ]
}
